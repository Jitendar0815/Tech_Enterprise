                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand">
-- Extract content metadata from staging table populated by REST API calls
SELECT 
    Source_System,
    External_Content_ID,
    Title,
    Content_Type,
    Genre,
    Description,
    Duration_Minutes,
    Release_Date,
    Production_Budget,
    Content_Rating,
    Language_Code,
    Country_Code,
    Director,
    Producer,
    Cast_List,
    Keywords,
    Thumbnail_URL,
    Trailer_URL,
    GETDATE() as Extract_Timestamp
FROM STG.Content_Metadata_Staging 
WHERE Processing_Status = 'Pending'
  AND Created_Date >= ?
ORDER BY Created_Date
                </property>
