                  dataType="System.String"
                  description="The script language."
                  name="ScriptLanguage">Microsoft Visual C# 2019</property>
                <property
                  dataType="System.String"
                  description="The script code."
                  name="ScriptCode">
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;
using System.Text.RegularExpressions;
using System.Linq;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    public override void PreExecute()
    {
        base.PreExecute();
    }

    public override void PostExecute()
    {
        base.PostExecute();
    }

    public override void Input0_ProcessInputRow(Input0Buffer Row)
    {
        // Content quality scoring
        Row.ContentQualityScore = CalculateContentQualityScore(Row);
        
        // Extract and clean metadata
        Row.CleanedTitle = CleanTitle(Row.Title);
        Row.ExtractedKeywords = ExtractKeywords(Row.Description);
        Row.ContentCategory = CategorizeContent(Row.ContentType, Row.Genre);
        
        // Calculate content metrics
        Row.EstimatedAudienceSize = EstimateAudienceSize(Row);
        Row.ContentComplexityScore = CalculateComplexityScore(Row);
        
        // Set processing flags
        Row.RequiresReview = RequiresManualReview(Row);
        Row.ProcessingTimestamp = DateTime.Now;
    }

    private int CalculateContentQualityScore(Input0Buffer Row)
    {
        int score = 50; // Base score
        
        // Title quality
        if (!string.IsNullOrEmpty(Row.Title) && Row.Title.Length > 10)
            score += 10;
        
        // Description quality
        if (!string.IsNullOrEmpty(Row.Description) && Row.Description.Length > 100)
            score += 15;
        
        // Metadata completeness
        if (!string.IsNullOrEmpty(Row.Genre)) score += 5;
        if (!string.IsNullOrEmpty(Row.Director)) score += 5;
        if (!string.IsNullOrEmpty(Row.Cast_List)) score += 5;
        if (!string.IsNullOrEmpty(Row.Keywords)) score += 10;
        
        return Math.Min(100, score);
    }

    private string CleanTitle(string title)
    {
        if (string.IsNullOrEmpty(title)) return "";
        
        // Remove special characters and normalize
        string cleaned = Regex.Replace(title, @"[^\w\s-]", "");
        cleaned = Regex.Replace(cleaned, @"\s+", " ");
        return cleaned.Trim();
    }

    private string ExtractKeywords(string description)
    {
        if (string.IsNullOrEmpty(description)) return "";
        
        // Simple keyword extraction (in production, use NLP libraries)
        var words = description.Split(' ')
            .Where(w => w.Length > 4)
            .Take(10)
            .ToArray();
        
        return string.Join(", ", words);
    }

    private string CategorizeContent(string contentType, string genre)
    {
        if (string.IsNullOrEmpty(contentType)) return "Unknown";
        
        // Categorize based on type and genre
        if (contentType.Contains("Movie"))
        {
            if (!string.IsNullOrEmpty(genre))
                return $"Movie - {genre}";
            return "Movie - General";
        }
        
        if (contentType.Contains("TV") || contentType.Contains("Series"))
            return "Television";
        
        if (contentType.Contains("Documentary"))
            return "Documentary";
        
        return contentType;
    }

    private int EstimateAudienceSize(Input0Buffer Row)
    {
        // Simple audience estimation algorithm
        int baseSize = 1000;
        
        if (Row.ContentType.Contains("Movie")) baseSize = 50000;
        if (Row.ContentType.Contains("TV")) baseSize = 25000;
        if (Row.ContentType.Contains("Documentary")) baseSize = 10000;
        
        // Adjust based on genre popularity
        if (!string.IsNullOrEmpty(Row.Genre))
        {
            if (Row.Genre.Contains("Action") || Row.Genre.Contains("Comedy"))
                baseSize = (int)(baseSize * 1.5);
            else if (Row.Genre.Contains("Drama"))
                baseSize = (int)(baseSize * 1.2);
        }
        
        return baseSize;
    }

    private int CalculateComplexityScore(Input0Buffer Row)
    {
        int complexity = 1; // Simple
        
        if (Row.Duration_Minutes > 120) complexity = 3; // Complex
        else if (Row.Duration_Minutes > 60) complexity = 2; // Medium
        
        if (!string.IsNullOrEmpty(Row.Genre) && 
            (Row.Genre.Contains("Sci-Fi") || Row.Genre.Contains("Fantasy")))
            complexity += 1;
        
        return Math.Min(5, complexity);
    }

    private bool RequiresManualReview(Input0Buffer Row)
    {
        // Flag content that needs manual review
        if (Row.ContentQualityScore < 60) return true;
        if (string.IsNullOrEmpty(Row.Title)) return true;
        if (string.IsNullOrEmpty(Row.Description)) return true;
        
        return false;
    }
}
