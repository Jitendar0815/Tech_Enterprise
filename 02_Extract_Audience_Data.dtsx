                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand">
-- Extract audience data from multiple platform staging tables
SELECT 
    'Netflix' as Platform_Name,
    User_ID,
    Registration_Date,
    Subscription_Type,
    Subscription_Start_Date,
    Subscription_End_Date,
    Age_Group,
    Gender,
    Geographic_Location,
    Device_Type,
    Preferred_Language,
    Viewing_Hours_Per_Week,
    Preferred_Genres,
    GETDATE() as Extract_Timestamp
FROM STG.Netflix_Users
WHERE Processing_Status = 'Pending'

UNION ALL

SELECT 
    'Amazon Prime' as Platform_Name,
    Customer_ID as User_ID,
    Account_Created as Registration_Date,
    Membership_Type as Subscription_Type,
    Membership_Start as Subscription_Start_Date,
    Membership_End as Subscription_End_Date,
    Demographics_Age as Age_Group,
    Demographics_Gender as Gender,
    Location as Geographic_Location,
    Primary_Device as Device_Type,
    Language_Preference as Preferred_Language,
    Weekly_Usage_Hours as Viewing_Hours_Per_Week,
    Content_Preferences as Preferred_Genres,
    GETDATE() as Extract_Timestamp
FROM STG.AmazonPrime_Users
WHERE Processing_Status = 'Pending'

UNION ALL

SELECT 
    'Disney+' as Platform_Name,
    Subscriber_ID as User_ID,
    Join_Date as Registration_Date,
    Plan_Type as Subscription_Type,
    Plan_Start_Date as Subscription_Start_Date,
    Plan_End_Date as Subscription_End_Date,
    User_Age_Range as Age_Group,
    User_Gender as Gender,
    Country_Region as Geographic_Location,
    Streaming_Device as Device_Type,
    UI_Language as Preferred_Language,
    Avg_Weekly_Hours as Viewing_Hours_Per_Week,
    Favorite_Categories as Preferred_Genres,
    GETDATE() as Extract_Timestamp
FROM STG.DisneyPlus_Users
WHERE Processing_Status = 'Pending'
