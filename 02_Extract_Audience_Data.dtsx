            <component
              refId="2"
              componentClassID="Microsoft.ScriptComponentTransform"
              contactInfo="Script Component;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;0"
              description="Script Component"
              name="Audience Analytics Processor"
              usesDispositions="true"
              version="0">
              <properties>
                <property
                  dataType="System.String"
                  description="The script language."
                  name="ScriptLanguage">Microsoft Visual C# 2019</property>
                <property
                  dataType="System.String"
                  description="The script code."
                  name="ScriptCode">
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;
using System.Text.RegularExpressions;
using System.Linq;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    public override void PreExecute()
    {
        base.PreExecute();
    }

    public override void PostExecute()
    {
        base.PostExecute();
    }

    public override void Input0_ProcessInputRow(Input0Buffer Row)
    {
        // Generate unique audience GUID
        Row.AudienceGUID = Guid.NewGuid().ToString();
        
        // Calculate audience metrics
        Row.EngagementScore = CalculateEngagementScore(Row);
        Row.LifetimeValue = EstimateLifetimeValue(Row);
        Row.ChurnRisk = CalculateChurnRisk(Row);
        
        // Demographic analysis
        Row.DemographicSegment = DetermineDemographicSegment(Row);
        Row.BehavioralSegment = DetermineBehavioralSegment(Row);
        
        // Platform-specific processing
        Row.PlatformTier = DeterminePlatformTier(Row);
        Row.ContentAffinityScore = CalculateContentAffinity(Row);
        
        // Data quality flags
        Row.DataQualityScore = CalculateDataQuality(Row);
        Row.RequiresEnrichment = RequiresDataEnrichment(Row);
        
        Row.ProcessingTimestamp = DateTime.Now;
    }

    private double CalculateEngagementScore(Input0Buffer Row)
    {
        double score = 50.0; // Base score
        
        // Viewing hours impact
        if (Row.Viewing_Hours_Per_Week > 20) score += 30;
        else if (Row.Viewing_Hours_Per_Week > 10) score += 20;
        else if (Row.Viewing_Hours_Per_Week > 5) score += 10;
        
        // Subscription longevity
        if (!Row.Subscription_Start_Date_IsNull && !Row.Registration_Date_IsNull)
        {
            var subscriptionDays = (DateTime.Now - Row.Subscription_Start_Date).Days;
            if (subscriptionDays > 365) score += 20;
            else if (subscriptionDays > 180) score += 15;
            else if (subscriptionDays > 90) score += 10;
        }
        
        // Premium subscription bonus
        if (!string.IsNullOrEmpty(Row.Subscription_Type) && 
            (Row.Subscription_Type.Contains("Premium") || Row.Subscription_Type.Contains("Plus")))
            score += 15;
        
        return Math.Min(100, score);
    }

    private decimal EstimateLifetimeValue(Input0Buffer Row)
    {
        decimal baseValue = 50.0m; // Base monthly value
        
        // Adjust based on subscription type
        if (!string.IsNullOrEmpty(Row.Subscription_Type))
        {
            if (Row.Subscription_Type.Contains("Premium")) baseValue = 19.99m;
            else if (Row.Subscription_Type.Contains("Standard")) baseValue = 15.99m;
            else if (Row.Subscription_Type.Contains("Basic")) baseValue = 9.99m;
        }
        
        // Calculate expected lifetime (months)
        int expectedLifetime = 24; // Default 2 years
        
        if (Row.Viewing_Hours_Per_Week > 15) expectedLifetime = 36; // 3 years for heavy users
        else if (Row.Viewing_Hours_Per_Week < 3) expectedLifetime = 12; // 1 year for light users
        
        return baseValue * expectedLifetime;
    }

    private double CalculateChurnRisk(Input0Buffer Row)
    {
        double risk = 20.0; // Base risk
        
        // Low engagement increases risk
        if (Row.Viewing_Hours_Per_Week < 2) risk += 40;
        else if (Row.Viewing_Hours_Per_Week < 5) risk += 20;
        
        // Subscription end date proximity
        if (!Row.Subscription_End_Date_IsNull)
        {
            var daysToExpiry = (Row.Subscription_End_Date - DateTime.Now).Days;
            if (daysToExpiry < 30) risk += 30;
            else if (daysToExpiry < 90) risk += 15;
        }
        
        // New users have higher churn risk initially
        if (!Row.Registration_Date_IsNull)
        {
            var daysSinceRegistration = (DateTime.Now - Row.Registration_Date).Days;
            if (daysSinceRegistration < 30) risk += 25;
            else if (daysSinceRegistration < 90) risk += 10;
        }
        
        return Math.Min(100, risk);
    }

    private string DetermineDemographicSegment(Input0Buffer Row)
    {
        string segment = "General";
        
        if (!string.IsNullOrEmpty(Row.Age_Group) && !string.IsNullOrEmpty(Row.Gender))
        {
            segment = $"{Row.Age_Group}_{Row.Gender}";
        }
        else if (!string.IsNullOrEmpty(Row.Age_Group))
        {
            segment = Row.Age_Group;
        }
        
        // Add geographic component if available
        if (!string.IsNullOrEmpty(Row.Geographic_Location))
        {
            var location = Row.Geographic_Location.Split(',')[0].Trim(); // Get first part
            segment += $"_{location}";
        }
        
        return segment;
    }

    private string DetermineBehavioralSegment(Input0Buffer Row)
    {
        if (Row.Viewing_Hours_Per_Week > 25) return "Binge_Watcher";
        if (Row.Viewing_Hours_Per_Week > 15) return "Heavy_User";
        if (Row.Viewing_Hours_Per_Week > 8) return "Regular_User";
        if (Row.Viewing_Hours_Per_Week > 3) return "Casual_User";
        return "Light_User";
    }

    private string DeterminePlatformTier(Input0Buffer Row)
    {
        if (!string.IsNullOrEmpty(Row.Subscription_Type))
        {
            if (Row.Subscription_Type.Contains("Premium") || Row.Subscription_Type.Contains("Plus"))
                return "Premium";
            if (Row.Subscription_Type.Contains("Standard"))
                return "Standard";
            if (Row.Subscription_Type.Contains("Basic"))
                return "Basic";
        }
        return "Free";
    }

    private double CalculateContentAffinity(Input0Buffer Row)
    {
        double affinity = 50.0;
        
        // More preferred genres indicate higher content engagement
        if (!string.IsNullOrEmpty(Row.Preferred_Genres))
        {
            var genreCount = Row.Preferred_Genres.Split(',').Length;
            if (genreCount > 5) affinity += 25;
            else if (genreCount > 3) affinity += 15;
            else if (genreCount > 1) affinity += 10;
        }
        
        // Platform-specific adjustments
        if (Row.Platform_Name == "Disney+" && 
            !string.IsNullOrEmpty(Row.Preferred_Genres) && 
            Row.Preferred_Genres.Contains("Animation"))
            affinity += 15;
        
        return Math.Min(100, affinity);
    }

    private int CalculateDataQuality(Input0Buffer Row)
    {
        int quality = 100;
        
        // Deduct points for missing critical data
        if (string.IsNullOrEmpty(Row.User_ID)) quality -= 30;
        if (Row.Registration_Date_IsNull) quality -= 15;
        if (string.IsNullOrEmpty(Row.Age_Group)) quality -= 10;
        if (string.IsNullOrEmpty(Row.Gender)) quality -= 10;
        if (string.IsNullOrEmpty(Row.Geographic_Location)) quality -= 10;
        if (Row.Viewing_Hours_Per_Week <= 0) quality -= 15;
        if (string.IsNullOrEmpty(Row.Preferred_Genres)) quality -= 10;
        
        return Math.Max(0, quality);
    }

    private bool RequiresDataEnrichment(Input0Buffer Row)
    {
        // Flag records that need additional data enrichment
        if (string.IsNullOrEmpty(Row.Age_Group)) return true;
        if (string.IsNullOrEmpty(Row.Gender)) return true;
        if (string.IsNullOrEmpty(Row.Geographic_Location)) return true;
        if (Row.Viewing_Hours_Per_Week <= 0) return true;
        
        return false;
    }
}
