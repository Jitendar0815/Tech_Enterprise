            <component
              refId="2"
              componentClassID="Microsoft.ScriptComponentTransform"
              contactInfo="Script Component;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;0"
              description="Script Component"
              name="Advanced Analytics Calculator"
              usesDispositions="true"
              version="0">
              <properties>
                <property
                  dataType="System.String"
                  description="The script language."
                  name="ScriptLanguage">Microsoft Visual C# 2019</property>
                <property
                  dataType="System.String"
                  description="The script code."
                  name="ScriptCode">
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    public override void Input0_ProcessInputRow(Input0Buffer Row)
    {
        // Calculate advanced performance metrics
        Row.RetentionRate = CalculateRetentionRate(Row);
        Row.ChurnRate = CalculateChurnRate(Row);
        Row.TrendingScore = CalculateTrendingScore(Row);
        Row.RecommendationScore = CalculateRecommendationScore(Row);
        Row.ViralityIndex = CalculateViralityIndex(Row);
        Row.QualityIndex = CalculateQualityIndex(Row);
        Row.PopularityRank = CalculatePopularityRank(Row);
        Row.ContentHealthScore = CalculateContentHealthScore(Row);
        
        // Set processing timestamp
        Row.AnalysisTimestamp = DateTime.Now;
    }

    private double CalculateRetentionRate(Input0Buffer Row)
    {
        if (Row.TotalSessions == 0) return 0;
        return (double)Row.UniqueViewers / Row.TotalSessions * 100;
    }

    private double CalculateChurnRate(Input0Buffer Row)
    {
        if (Row.TotalSessions == 0) return 0;
        return (double)Row.SkippedSessions / Row.TotalSessions * 100;
    }

    private double CalculateTrendingScore(Input0Buffer Row)
    {
        double score = 0;
        
        // Base score from engagement
        score += Row.AvgEngagementScore * 0.4;
        
        // Completion rate impact
        score += Row.AvgCompletionRate * 0.3;
        
        // User rating impact
        if (!Row.AvgUserRating_IsNull)
            score += (Row.AvgUserRating / 5.0) * 100 * 0.2;
        
        // Recency boost (newer content gets higher trending score)
        if (!Row.Release_Date_IsNull)
        {
            var daysSinceRelease = (DateTime.Now - Row.Release_Date).Days;
            if (daysSinceRelease <= 7) score += 20;
            else if (daysSinceRelease <= 30) score += 10;
            else if (daysSinceRelease <= 90) score += 5;
        }
        
        // Volume boost
        if (Row.TotalSessions > 10000) score += 15;
        else if (Row.TotalSessions > 1000) score += 10;
        else if (Row.TotalSessions > 100) score += 5;
        
        return Math.Min(100, score);
    }

    private double CalculateRecommendationScore(Input0Buffer Row)
    {
        double score = 50; // Base score
        
        // High completion rate boosts recommendation
        score += Row.AvgCompletionRate * 0.3;
        
        // High engagement boosts recommendation
        score += Row.AvgEngagementScore * 0.2;
        
        // User rating impact
        if (!Row.AvgUserRating_IsNull)
            score += (Row.AvgUserRating - 3) * 10; // Boost for ratings above 3
        
        // Low churn rate is good for recommendations
        var churnRate = CalculateChurnRate(Row);
        score += (100 - churnRate) * 0.1;
        
        // Geographic and device diversity indicates broad appeal
        score += Row.GeographicReach * 2;
        score += Row.DeviceVariety * 3;
        
        return Math.Min(100, Math.Max(0, score));
    }

    private double CalculateViralityIndex(Input0Buffer Row)
    {
        double index = 0;
        
        // High unique viewer to session ratio indicates sharing
        if (Row.TotalSessions > 0)
        {
            var viewerSessionRatio = (double)Row.UniqueViewers / Row.TotalSessions;
            if (viewerSessionRatio > 0.8) index += 30;
            else if (viewerSessionRatio > 0.6) index += 20;
            else if (viewerSessionRatio > 0.4) index += 10;
        }
        
        // Geographic reach indicates viral spread
        index += Math.Min(30, Row.GeographicReach * 3);
        
        // Device variety indicates cross-platform sharing
        index += Math.Min(20, Row.DeviceVariety * 5);
        
        // High engagement with low buffer issues indicates quality viral content
        if (Row.BufferingIssues < Row.TotalSessions * 0.1) // Less than 10% buffering issues
            index += Row.AvgEngagementScore * 0.2;
        
        return Math.Min(100, index);
    }

    private double CalculateQualityIndex(Input0Buffer Row)
    {
        double quality = 0;
        
        // Low buffering issues indicate good technical quality
        if (Row.TotalSessions > 0)
        {
            var bufferingRate = (double)Row.BufferingIssues / Row.TotalSessions;
            quality += (1 - bufferingRate) * 30;
        }
        
        // High completion rate indicates content quality
        quality += Row.AvgCompletionRate * 0.4;
        
        // User rating directly reflects quality
        if (!Row.AvgUserRating_IsNull)
            quality += (Row.AvgUserRating / 5.0) * 40;
        
        // Low skip rate indicates engaging content
        if (Row.TotalSessions > 0)
        {
            var skipRate = (double)Row.SkippedSessions / Row.TotalSessions;
            quality += (1 - skipRate) * 20;
        }
        
        return Math.Min(100, quality);
    }

    private int CalculatePopularityRank(Input0Buffer Row)
    {
        // Simple popularity ranking based on total sessions
        // In production, this would be calculated across all content
        if (Row.TotalSessions > 50000) return 1; // Top tier
        if (Row.TotalSessions > 10000) return 2; // High popularity
        if (Row.TotalSessions > 1000) return 3;  // Medium popularity
        if (Row.TotalSessions > 100) return 4;   // Low popularity
        return 5; // Minimal popularity
    }

    private double CalculateContentHealthScore(Input0Buffer Row)
    {
        double health = 0;
        
        // Combine multiple health indicators
        health += CalculateQualityIndex(Row) * 0.3;
        health += Row.AvgEngagementScore * 0.25;
        health += Row.AvgCompletionRate * 0.25;
        health += (100 - CalculateChurnRate(Row)) * 0.2;
        
        return Math.Min(100, health);
    }
}
