    <!-- Execute Advanced Analytics -->
    <DTS:Executable
      DTS:refId="Package\Execute SQL Task - Advanced Analytics"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute advanced analytics procedures"
      DTS:DTSID="{A7B8C9D0-E1F2-3456-0123-789012345678}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task - Advanced Analytics">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B8C9D0E1-F2G3-4567-1234-890123456789}"
          SQLTask:SqlStatementSource="
-- Execute comprehensive analytics procedures
DECLARE @ProcessingDate DATE = CAST(? AS DATE);
DECLARE @RecordsProcessed INT = 0;

-- Calculate content performance metrics
EXEC Media.sp_CalculateContentPerformanceMetrics 
    @StartDate = @ProcessingDate,
    @EndDate = @ProcessingDate;

SET @RecordsProcessed = @RecordsProcessed + @@ROWCOUNT;

-- Generate audience segments
EXEC Media.sp_GenerateAudienceSegments 
    @AnalysisDate = @ProcessingDate;

SET @RecordsProcessed = @RecordsProcessed + @@ROWCOUNT;

-- Calculate revenue metrics
EXEC Media.sp_CalculateRevenueMetrics 
    @StartDate = @ProcessingDate,
    @EndDate = @ProcessingDate;

SET @RecordsProcessed = @RecordsProcessed + @@ROWCOUNT;

-- Analyze social engagement
EXEC Media.sp_AnalyzeSocialEngagement 
    @StartDate = @ProcessingDate,
    @EndDate = @ProcessingDate;

SET @RecordsProcessed = @RecordsProcessed + @@ROWCOUNT;

-- Generate content recommendations for active users
EXEC Media.sp_GenerateContentRecommendations 
    @TopN = 10;

SET @RecordsProcessed = @RecordsProcessed + @@ROWCOUNT;

-- Monitor data quality
EXEC Media.sp_MonitorDataQuality;

-- Optimize performance
EXEC Media.sp_OptimizePerformance;

-- Return processing summary
SELECT @RecordsProcessed as RecordsProcessed;
          "
          SQLTask:ResultSetType="ResultSetType_SingleRow"
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="User::ProcessingDate"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="135"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="RecordsProcessed"
            SQLTask:DtsVariableName="User::TotalRecordsProcessed" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- Finalize Processing -->
    <DTS:Executable
      DTS:refId="Package\Execute SQL Task - Finalize Processing"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Finalize the media analytics processing session"
      DTS:DTSID="{C9D0E1F2-G3H4-5678-2345-901234567890}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task - Finalize Processing">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D0E1F2G3-H4I5-6789-3456-012345678901}"
          SQLTask:SqlStatementSource="
-- Finalize processing session
DECLARE @ExecutionID UNIQUEIDENTIFIER = CAST(? AS UNIQUEIDENTIFIER);
DECLARE @RecordsProcessed INT = ?;
DECLARE @EndTime DATETIME2 = GETDATE();

-- Update the process log
UPDATE LOG.ETL_Process_Log 
SET 
    End_Time = @EndTime,
    Status = 'Success',
    Records_Processed = @RecordsProcessed
WHERE Execution_ID = @ExecutionID;

-- Log summary statistics
INSERT INTO LOG.ETL_Process_Log 
(Process_Name, Package_Name, Start_Time, End_Time, Status, Records_Processed, Execution_ID)
VALUES 
('Media Analytics Processing Summary', 'Master Orchestration', @EndTime, @EndTime, 'Completed', @RecordsProcessed, @ExecutionID);

-- Generate processing report
SELECT 
    'Media Analytics Processing Completed Successfully' as ProcessingStatus,
    @RecordsProcessed as TotalRecordsProcessed,
    @EndTime as CompletionTime,
    DATEDIFF(MINUTE, (SELECT MIN(Start_Time) FROM LOG.ETL_Process_Log WHERE Execution_ID = @ExecutionID), @EndTime) as ProcessingDurationMinutes;
          "
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="User::ExecutionID"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="1"
            SQLTask:DtsVariableName="User::TotalRecordsProcessed"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="3"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- Send Notification -->
    <DTS:Executable
      DTS:refId="Package\Send Mail Task - Processing Complete"
      DTS:CreationName="Microsoft.SendMailTask"
      DTS:Description="Send notification email about processing completion"
      DTS:DTSID="{E1F2G3H4-I5J6-7890-4567-123456789012}"
      DTS:ExecutableType="Microsoft.SendMailTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Send Mail Task - Processing Complete">
      <DTS:Variables />
      <DTS:ObjectData>
        <SendMailTask:SendMailTaskData
          SendMailTask:SMTPServer="smtp.company.com"
          SendMailTask:From="ssis-notifications@company.com"
          SendMailTask:To="analytics-team@company.com"
          SendMailTask:Subject="Media Analytics Processing Completed Successfully"
          SendMailTask:MessageSource="The Media Entertainment Analytics processing has completed successfully.

Processing Summary:
- Execution ID: " + @[User::ExecutionID] + "
- Processing Date: " + (DT_WSTR, 20) @[User::ProcessingDate] + "
- Total Records Processed: " + (DT_WSTR, 10) @[User::TotalRecordsProcessed] + "
- Status: " + @[User::ProcessingStatus] + "

All packages executed successfully:
✓ Content Metadata Extraction
✓ Audience Data Extraction  
✓ Streaming Analytics Extraction
✓ Social Media Data Extraction
✓ Revenue Data Extraction
✓ Content Analytics Transformation
✓ Audience Segmentation Transformation
✓ Performance Metrics Transformation
✓ Media Warehouse Loading
✓ Advanced Analytics Processing

The media analytics data warehouse has been updated with the latest information and is ready for business intelligence reporting and analysis.

Best regards,
SSIS Media Analytics Platform"
          SendMailTask:MessageSourceType="DirectInput"
          xmlns:SendMailTask="www.microsoft.com/sqlserver/dts/tasks/sendmailtask" />
      </DTS:ObjectData>
    </DTS:Executable>
