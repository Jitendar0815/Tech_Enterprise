<?xml version="1.0" encoding="utf-8"?>
<ContentAnalyticsConfiguration>
  <GeneralSettings>
    <AnalysisFrequency>Daily</AnalysisFrequency>
    <RetentionPeriodDays>2555</RetentionPeriodDays>
    <EnableRealTimeProcessing>true</EnableRealTimeProcessing>
    <DefaultBatchSize>10000</DefaultBatchSize>
    <MaxConcurrentProcesses>4</MaxConcurrentProcesses>
  </GeneralSettings>

  <PerformanceMetrics>
    <ViewCountThresholds>
      <Threshold level="Low" min="0" max="1000" />
      <Threshold level="Medium" min="1001" max="10000" />
      <Threshold level="High" min="10001" max="100000" />
      <Threshold level="Viral" min="100001" max="999999999" />
    </ViewCountThresholds>
    
    <EngagementRateThresholds>
      <Threshold level="Poor" min="0" max="20" />
      <Threshold level="Average" min="21" max="50" />
      <Threshold level="Good" min="51" max="80" />
      <Threshold level="Excellent" min="81" max="100" />
    </EngagementRateThresholds>
    
    <CompletionRateThresholds>
      <Threshold level="Low" min="0" max="30" />
      <Threshold level="Medium" min="31" max="60" />
      <Threshold level="High" min="61" max="85" />
      <Threshold level="Exceptional" min="86" max="100" />
    </CompletionRateThresholds>
    
    <WatchTimeThresholds>
      <Threshold contentType="Short Form" min="0.5" max="5" unit="minutes" />
      <Threshold contentType="Medium Form" min="5" max="30" unit="minutes" />
      <Threshold contentType="Long Form" min="30" max="180" unit="minutes" />
      <Threshold contentType="Feature Length" min="60" max="300" unit="minutes" />
    </WatchTimeThresholds>
  </PerformanceMetrics>

  <AudienceSegmentation>
    <BehavioralSegments>
      <Segment name="Power User">
        <Criteria>
          <MinSessions>50</MinSessions>
          <MinCompletionRate>80</MinCompletionRate>
          <MinEngagementScore>75</MinEngagementScore>
        </Criteria>
        <Actions>
          <Action type="Recommendation">Prioritize premium content</Action>
          <Action type="Marketing">Target with exclusive offers</Action>
        </Actions>
      </Segment>
      
      <Segment name="Regular Viewer">
        <Criteria>
          <MinSessions>20</MinSessions>
          <MinCompletionRate>60</MinCompletionRate>
          <MinEngagementScore>50</MinEngagementScore>
        </Criteria>
        <Actions>
          <Action type="Recommendation">Suggest similar content</Action>
          <Action type="Marketing">Encourage subscription upgrade</Action>
        </Actions>
      </Segment>
      
      <Segment name="Content Explorer">
        <Criteria>
          <MinUniqueContent>20</MinUniqueContent>
          <MinWatchDuration>30</MinWatchDuration>
          <MaxCompletionRate>70</MaxCompletionRate>
        </Criteria>
        <Actions>
          <Action type="Recommendation">Diverse content recommendations</Action>
          <Action type="Marketing">Highlight content variety</Action>
        </Actions>
      </Segment>
      
      <Segment name="Browser">
        <Criteria>
          <MaxCompletionRate>30</MaxCompletionRate>
          <MinSessions>5</MinSessions>
        </Criteria>
        <Actions>
          <Action type="Recommendation">Shorter content formats</Action>
          <Action type="Marketing">Focus on engaging previews</Action>
        </Actions>
      </Segment>
      
      <Segment name="Casual Viewer">
        <Criteria>
          <MaxSessions>19</MaxSessions>
          <MinCompletionRate>30</MinCompletionRate>
        </Criteria>
        <Actions>
          <Action type="Recommendation">Popular trending content</Action>
          <Action type="Marketing">Engagement campaigns</Action>
        </Actions>
      </Segment>
      
      <Segment name="Inactive">
        <Criteria>
          <MaxDaysSinceLastActivity>30</MaxDaysSinceLastActivity>
        </Criteria>
        <Actions>
          <Action type="Recommendation">Re-engagement content</Action>
          <Action type="Marketing">Win-back campaigns</Action>
        </Actions>
      </Segment>
    </BehavioralSegments>
    
    <DemographicSegments>
      <AgeGroups>
        <Group name="Gen Z" min="18" max="24">
          <PreferredGenres>Action,Comedy,Animation</PreferredGenres>
          <PreferredPlatforms>TikTok,Instagram,YouTube</PreferredPlatforms>
          <OptimalContentLength>5-15</OptimalContentLength>
        </Group>
        <Group name="Millennials" min="25" max="40">
          <PreferredGenres>Drama,Comedy,Documentary</PreferredGenres>
          <PreferredPlatforms>Netflix,Hulu,YouTube</PreferredPlatforms>
          <OptimalContentLength>20-60</OptimalContentLength>
        </Group>
        <Group name="Gen X" min="41" max="56">
          <PreferredGenres>Drama,Action,Documentary</PreferredGenres>
          <PreferredPlatforms>Netflix,Amazon Prime,Cable TV</PreferredPlatforms>
          <OptimalContentLength>45-120</OptimalContentLength>
        </Group>
        <Group name="Baby Boomers" min="57" max="75">
          <PreferredGenres>News,Documentary,Drama</PreferredGenres>
          <PreferredPlatforms>Broadcast TV,Cable TV,Netflix</PreferredPlatforms>
          <OptimalContentLength>30-90</OptimalContentLength>
        </Group>
      </AgeGroups>
    </DemographicSegments>
  </AudienceSegmentation>

  <ContentRecommendations>
    <AlgorithmWeights>
      <Weight factor="GenreMatch" value="0.30" />
      <Weight factor="TrendingScore" value="0.20" />
      <Weight factor="UserRating" value="0.20" />
      <Weight factor="SimilarAudience" value="0.15" />
      <Weight factor="Recency" value="0.10" />
      <Weight factor="Platform" value="0.05" />
    </AlgorithmWeights>
    
    <RecommendationRules>
      <Rule name="GenreAffinity">
        <Description>Recommend content from user's preferred genres</Description>
        <MinGenreScore>70</MinGenreScore>
        <MaxRecommendations>5</MaxRecommendations>
      </Rule>
      
      <Rule name="TrendingContent">
        <Description>Recommend currently trending content</Description>
        <MinTrendingScore>80</MinTrendingScore>
        <MaxAge>7</MaxAge>
        <MaxRecommendations>3</MaxRecommendations>
      </Rule>
      
      <Rule name="HighlyRated">
        <Description>Recommend highly rated content</Description>
        <MinRating>4.0</MinRating>
        <MinReviews>100</MinReviews>
        <MaxRecommendations>3</MaxRecommendations>
      </Rule>
      
      <Rule name="SimilarAudience">
        <Description>Recommend content liked by similar users</Description>
        <MinSimilarityScore>75</MinSimilarityScore>
        <MaxRecommendations>4</MaxRecommendations>
      </Rule>
    </RecommendationRules>
    
    <ExclusionRules>
      <Rule name="RecentlyWatched">
        <Description>Exclude content watched in last 30 days</Description>
        <ExclusionPeriodDays>30</ExclusionPeriodDays>
      </Rule>
      
      <Rule name="LowRated">
        <Description>Exclude content with poor ratings</Description>
        <MaxRating>2.0</MaxRating>
      </Rule>
      
      <Rule name="AgeRestricted">
        <Description>Exclude age-inappropriate content</Description>
        <CheckAgeRestrictions>true</CheckAgeRestrictions>
      </Rule>
    </ExclusionRules>
  </ContentRecommendations>

  <SocialMediaAnalytics>
    <PlatformWeights>
      <Platform name="Twitter" weight="0.25" />
      <Platform name="Facebook" weight="0.20" />
      <Platform name="Instagram" weight="0.20" />
      <Platform name="TikTok" weight="0.15" />
      <Platform name="YouTube" weight="0.10" />
      <Platform name="Reddit" weight="0.10" />
    </PlatformWeights>
    
    <SentimentAnalysis>
      <SentimentThresholds>
        <Threshold category="Very Positive" min="0.6" max="1.0" />
        <Threshold category="Positive" min="0.2" max="0.59" />
        <Threshold category="Neutral" min="-0.19" max="0.19" />
        <Threshold category="Negative" min="-0.59" max="-0.2" />
        <Threshold category="Very Negative" min="-1.0" max="-0.6" />
      </SentimentThresholds>
      
      <AlertThresholds>
        <Alert type="NegativeTrend" threshold="-0.3" />
        <Alert type="ViralPositive" threshold="0.7" />
        <Alert type="HighEngagement" engagementCount="10000" />
      </AlertThresholds>
    </SentimentAnalysis>
    
    <TrendingAnalysis>
      <HashtagTracking>
        <MinMentions>50</MinMentions>
        <TimeWindow>24</TimeWindow>
        <TrendingThreshold>200</TrendingThreshold>
      </HashtagTracking>
      
      <InfluencerTracking>
        <MinFollowers>10000</MinFollowers>
        <EngagementRateThreshold>3.0</EngagementRateThreshold>
      </InfluencerTracking>
    </TrendingAnalysis>
  </SocialMediaAnalytics>

  <RevenueOptimization>
    <MonetizationStrategies>
      <Strategy name="Subscription">
        <TargetAudience>Regular Viewer,Power User</TargetAudience>
        <OptimalPricing currency="USD">
          <Tier name="Basic" price="9.99" />
          <Tier name="Standard" price="15.99" />
          <Tier name="Premium" price="19.99" />
        </OptimalPricing>
      </Strategy>
      
      <Strategy name="Advertisement">
        <TargetAudience>Casual Viewer,Browser</TargetAudience>
        <AdFrequency>
          <PreRoll enabled="true" maxDuration="30" />
          <MidRoll enabled="true" frequency="15" maxDuration="15" />
          <PostRoll enabled="false" />
        </AdFrequency>
      </Strategy>
      
      <Strategy name="PayPerView">
        <TargetAudience>Content Explorer</TargetAudience>
        <PricingModel>
          <Movie>4.99</Movie>
          <TVEpisode>1.99</TVEpisode>
          <LiveEvent>9.99</LiveEvent>
        </PricingModel>
      </Strategy>
    </MonetizationStrategies>
    
    <RevenueMetrics>
      <KPIs>
        <KPI name="ARPU" target="25.00" unit="USD" />
        <KPI name="LTV" target="150.00" unit="USD" />
        <KPI name="ChurnRate" target="5.0" unit="percent" />
        <KPI name="ConversionRate" target="15.0" unit="percent" />
      </KPIs>
    </RevenueMetrics>
  </RevenueOptimization>

  <QualityAssurance>
    <DataValidationRules>
      <Rule table="Content_Master" column="Title" type="NotNull" />
      <Rule table="Content_Master" column="Duration_Minutes" type="Positive" />
      <Rule table="Content_Consumption" column="User_Rating" type="Range" min="1" max="5" />
      <Rule table="Content_Consumption" column="Completion_Percentage" type="Range" min="0" max="100" />
      <Rule table="Content_Consumption" column="Watch_Duration_Minutes" type="Positive" />
      <Rule table="Revenue_Analytics" column="Gross_Revenue" type="NonNegative" />
      <Rule table="Social_Media_Engagement" column="Sentiment_Score" type="Range" min="-1" max="1" />
    </DataValidationRules>
    
    <AlertingRules>
      <Alert name="DataQualityIssue" threshold="5" unit="percent" />
      <Alert name="ProcessingDelay" threshold="60" unit="minutes" />
      <Alert name="HighErrorRate" threshold="1" unit="percent" />
    </AlertingRules>
  </QualityAssurance>

  <PerformanceOptimization>
    <IndexingStrategy>
      <Index table="Content_Consumption" columns="ContentID,Session_Start_Time" />
      <Index table="Content_Performance" columns="ContentID,Metric_Date" />
      <Index table="Revenue_Analytics" columns="ContentID,Revenue_Date" />
      <Index table="Social_Media_Engagement" columns="ContentID,Engagement_Date" />
    </IndexingStrategy>
    
    <CachingStrategy>
      <Cache name="PopularContent" ttl="3600" />
      <Cache name="TrendingContent" ttl="1800" />
      <Cache name="UserRecommendations" ttl="7200" />
    </CachingStrategy>
    
    <PartitioningStrategy>
      <Partition table="Content_Consumption" column="Session_Start_Time" type="Monthly" />
      <Partition table="Content_Performance" column="Metric_Date" type="Monthly" />
      <Partition table="Revenue_Analytics" column="Revenue_Date" type="Monthly" />
    </PartitioningStrategy>
  </PerformanceOptimization>

  <ComplianceSettings>
    <DataRetention>
      <Policy name="PersonalData" retentionDays="2555" />
      <Policy name="AnalyticsData" retentionDays="2555" />
      <Policy name="LogData" retentionDays="365" />
    </DataRetention>
    
    <PrivacySettings>
      <AnonymizationRules>
        <Rule field="UserID" method="Hash" />
        <Rule field="IPAddress" method="Mask" />
        <Rule field="DeviceID" method="Encrypt" />
      </AnonymizationRules>
      
      <ConsentManagement>
        <RequiredConsent>Analytics,Marketing,Personalization</RequiredConsent>
        <OptionalConsent>SocialSharing,ThirdPartyIntegration</OptionalConsent>
      </ConsentManagement>
    </PrivacySettings>
  </ComplianceSettings>
</ContentAnalyticsConfiguration>